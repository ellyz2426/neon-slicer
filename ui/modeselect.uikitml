<style>
  .panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3;
    padding-left: 4;
    padding-right: 4;
    background-color: rgba(0, 0, 0, 0.85);
    border-color: #00ffff;
    border-width: 0.15;
    border-radius: 1.5;
    gap: 0.8;
  }
  .heading {
    font-size: 3;
    color: #00ffff;
    font-weight: bold;
  }
  .btn {
    font-size: 1.6;
    color: #ffffff;
    background-color: rgba(0, 255, 255, 0.15);
    border-color: #00ffff;
    border-width: 0.1;
    border-radius: 0.8;
    padding: 0.6;
    padding-left: 2;
    padding-right: 2;
    cursor: pointer;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .desc {
    font-size: 1;
    color: #888888;
  }
  .btn-back {
    background-color: rgba(255, 0, 255, 0.15);
    border-color: #ff00ff;
  }
  .btn-endless {
    background-color: rgba(255, 170, 0, 0.2);
    border-color: #ffaa00;
    color: #ffcc00;
  }
  .btn-mod {
    background-color: rgba(136, 68, 204, 0.2);
    border-color: #8844cc;
    color: #aa88ee;
  }
  .btn-season {
    background-color: rgba(255, 215, 0, 0.2);
    border-color: #ffd700;
    color: #ffd700;
  }
</style>
<div class="panel">
  <span class="heading">SELECT MODE</span>
  <div id="btn-classic" class="btn" cursor="pointer">CLASSIC</div>
  <span class="desc">Waves of objects, 3 lives</span>
  <div id="btn-zen" class="btn" cursor="pointer">ZEN</div>
  <span class="desc">No bombs, no pressure</span>
  <div id="btn-timeattack" class="btn" cursor="pointer">TIME ATTACK</div>
  <span class="desc">60 seconds, max score</span>
  <div id="btn-survival" class="btn" cursor="pointer">SURVIVAL</div>
  <span class="desc">Rising difficulty, 3 lives</span>
  <div id="btn-frenzy" class="btn" cursor="pointer">FRENZY</div>
  <span class="desc">30s rapid fire, no bombs</span>
  <div id="btn-daily" class="btn" cursor="pointer">DAILY CHALLENGE</div>
  <span class="desc">Same puzzle for everyone today</span>
  <div id="btn-precision" class="btn" cursor="pointer">PRECISION</div>
  <span class="desc">Slice only marked targets, 3 lives</span>
  <div id="btn-endless" class="btn btn-endless" cursor="pointer">ENDLESS</div>
  <span class="desc">Infinite waves, how far can you go?</span>
  <div id="btn-season" class="btn btn-season" cursor="pointer">SEASON</div>
  <span class="desc">Defeat 8 AI opponents to become champion</span>
  <div id="btn-modifiers" class="btn btn-mod" cursor="pointer">MODIFIERS</div>
  <span class="desc">Toggle challenge mutators</span>
  <div id="btn-back-mode" class="btn btn-back" cursor="pointer">BACK</div>
</div>
