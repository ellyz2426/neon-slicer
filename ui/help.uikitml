<style>
  .panel {
    display: flex;
    flex-direction: column;
    padding: 2;
    padding-left: 3;
    padding-right: 3;
    background-color: rgba(0, 0, 0, 0.85);
    border-color: #00ffff;
    border-width: 0.15;
    border-radius: 1.5;
    gap: 0.6;
  }
  .heading {
    font-size: 2.5;
    color: #00ffff;
    font-weight: bold;
  }
  .section {
    font-size: 1.4;
    color: #ff00ff;
    font-weight: bold;
  }
  .text {
    font-size: 1.1;
    color: #cccccc;
  }
  .key {
    font-size: 1.1;
    color: #00ffff;
  }
  .btn {
    font-size: 1.8;
    color: #ffffff;
    background-color: rgba(0, 255, 255, 0.15);
    border-color: #00ffff;
    border-width: 0.1;
    border-radius: 0.8;
    padding: 0.8;
    padding-left: 2;
    padding-right: 2;
    cursor: pointer;
