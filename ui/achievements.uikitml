<style>
  .panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2;
    padding-left: 3;
    padding-right: 3;
    background-color: rgba(0, 0, 0, 0.85);
    border-color: #00ff80;
    border-width: 0.15;
    border-radius: 1.5;
    gap: 0.4;
  }
  .heading {
    font-size: 2.5;
    color: #00ff80;
    font-weight: bold;
  }
  .entry {
    display: flex;
    flex-direction: row;
    gap: 1;
    width: 100%;
    padding: 0.2;
    padding-left: 0.5;
    padding-right: 0.5;
  }
  .check { font-size: 1.2; color: #444444; width: 8%; }
  .check-done { font-size: 1.2; color: #00ff80; width: 8%; }
  .name { font-size: 1.2; color: #ffffff; width: 40%; }
  .desc { font-size: 1; color: #888888; width: 52%; }
  .page-info { font-size: 1.2; color: #888888; }
  .btn {
