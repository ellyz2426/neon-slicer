    background-color: rgba(0, 255, 128, 0.15);
    border-color: #00ff80;
    border-width: 0.1;
    border-radius: 0.8;
    padding: 0.6;
    padding-left: 2;
    padding-right: 2;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .nav-row {
    display: flex;
    flex-direction: row;
    gap: 2;
    width: 100%;
    justify-content: center;
  }
</style>
